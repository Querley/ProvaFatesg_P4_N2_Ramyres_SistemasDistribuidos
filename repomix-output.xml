  <p>Meta Q2: 15</p>
</div>
```

**Vue 3:**
```vue
<template>
  <div class="bg-surface-container-lowest border...">
    <span class="material-symbols-outlined">{{ metric.icon }}</span>
    <h3 class="text-label-md">{{ metric.title }}</h3>
    <h2 class="text-headline-lg">{{ metric.value }}</h2>
    <p>{{ metric.subtitle }}</p>
  </div>
</template>

<script setup lang="ts">
