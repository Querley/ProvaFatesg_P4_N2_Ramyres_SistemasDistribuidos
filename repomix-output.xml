```

### Tabelas Dinâmicas

**HTML:**
```html
<tr>
  <td>Tecnologia</td>
  <td>Amanda Lima</td>
  <td>342</td>
  <td>R$ 1.850.000</td>
  <td><span class="bg-tertiary-fixed-dim...">No Orçamento</span></td>
</tr>
```

**Vue 3:**
```vue
<tbody>
  <tr v-for="dept in departments" :key="dept.id">
    <td>{{ dept.name }}</td>
    <td>{{ dept.leader }}</td>
    <td>{{ dept.headcount }}</td>
    <td>{{ dept.budget }}</td>
    <td>
      <StatusBadge :status="dept.status" />
    </td>
  </tr>
</tbody>

<script setup lang="ts">
interface Department {
  id: string
  name: string
  leader: string
